{
  "manifest_version": 3,
  "name": "Cursorful",
  "description": "极简屏幕录制器：一键录屏、自动追踪鼠标，录制完成直接下载。",
  "version": "0.2.0",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Cursorful 录制器",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}